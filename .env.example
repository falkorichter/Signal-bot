# Signal FAQ Bot — Environment Variables
# Copy this file to .env and fill in your values.
# python-dotenv (optional) will load it automatically when the bot starts.

# ── Signal / signal-cli ────────────────────────────────────────────────────
# Your bot account's Signal phone number (required)
SIGNAL_NUMBER=+1234567890

# Base64-encoded Signal group ID to monitor.
# Leave empty to respond to questions from any source.
MONITOR_GROUP=

# ── Local LLM (ollama) ─────────────────────────────────────────────────────
# Model name — must be pulled with: ollama pull <model>
LLM_MODEL=llama3

# ollama generate API endpoint
LLM_API_URL=http://localhost:11434/api/generate

# ── FAQ database ───────────────────────────────────────────────────────────
FAQ_FILE=faqs.txt

# ── Polling ────────────────────────────────────────────────────────────────
# Seconds between signal-cli receive calls
POLL_INTERVAL=5

# ── Internationalisation ───────────────────────────────────────────────────
# Language for bot message templates (en_US, de, es, fr, ja, pt, zh_CN)
BOT_LANGUAGE=en_US

# ── Message template overrides (bypasses i18n when set) ───────────────────
# Leave these empty to use the locale files.
MESSAGE_PREFIX=
MESSAGE_SUFFIX=

# ── Web dashboard ──────────────────────────────────────────────────────────
# Sessions are persisted to data/sessions.json by default (no env var needed).

# ── Configurable pipeline commands ────────────────────────────────────────────
# Question detection: $input$ is substituted with the message text.
# Must print "true" or "false" to stdout.
QUESTION_CHECK_COMMAND=python3 check_question.py "$input$"

# Calendar fetch: output is captured and passed to LLM_COMMAND.
CALENDAR_COMMAND=python3 fetch_appointments.py

# LLM query: $input$ = user question, $calendar_appointments$ = calendar text.
# apfel example (Apple Intelligence, macOS 26+):
#   LLM_COMMAND=apfel "$calendar_appointments$ These are the next appointments. $input$"
# ollama example:
#   LLM_COMMAND=ollama run llama3 "$calendar_appointments$ $input$"
LLM_COMMAND=python3 query_llm.py "$input$"

# ── Token window ──────────────────────────────────────────────────────────────
# apfel has a fixed 4096-token context window.
# Increase when using a model with a larger context (e.g. 8192, 32768).
TOKEN_WINDOW=4096
